# Build artifacts
target/
**/target/

# macOS
.DS_Store

# IDE
.vscode/
*.swp
*.swo

# OODA scratch artefacts (keep dir, ignore contents)
.ooda/*
!.ooda/.gitkeep

# LLM scratch notes (pre-research drafts, not intentional docs)
docs/notes/

# Beads / Dolt files (added by bd init)
.dolt/

# Beads issues export — internal planning history, not for public history.
# bd regenerates this file from the Dolt store; ignoring it keeps it local.
.beads/issues.jsonl
.beads/events.jsonl

# opencode plugin deps
.opencode/node_modules/
*.db
.beads-credential-key

# gh-report runtime storage (--store-dir default is "store"); also catch
# any per-crate runs that materialise a nested store/ tree.
store/
**/store/

# Bespoke scripts. The Track-4 experiment (prod-loc, track4-verify, awk
# loc/adr counters, citation-diff) was retracted 2026-05-16 — drift +
# clutter cost exceeded the value delivered (most criteria already
# enforced by `cargo test` / `cargo clippy` / `cargo fmt` CI jobs).
# Keep this directory ignored so future throwaway tooling does not
# silently accumulate in git history. Promote any genuinely durable
# tool to its own crate under `crates/` with an ADR justifying it.
scripts/
