# Build artifacts
target/

# macOS
.DS_Store

# IDE
.vscode/
*.swp
*.swo

# OODA scratch artefacts (keep dir, ignore contents)
.ooda/*
!.ooda/.gitkeep

# LLM scratch notes (pre-research drafts, not intentional docs)
docs/notes/

# Beads / Dolt files (added by bd init)
.dolt/

# Beads issues export — internal planning history, not for public history.
# bd regenerates this file from the Dolt store; ignoring it keeps it local.
.beads/issues.jsonl
.beads/events.jsonl

# Ad-hoc analysis scripts (awk/etc.); not part of shipped tooling
scripts/

# opencode plugin deps
.opencode/node_modules/
*.db
.beads-credential-key

# gh-report runtime storage (--store-dir default is "store"); also catch
# any per-crate runs that materialise a nested store/ tree.
store/
**/store/
