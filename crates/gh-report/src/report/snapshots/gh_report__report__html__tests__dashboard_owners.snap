<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Owner Coverage — TestOrg</title>
    <link rel="stylesheet" href="style.css">
    <script src="ws.js" defer></script>
    <script type="module" src="sort-init.js"></script>
    
</head>
<body>

<nav class="top-nav">
    <a href="index.html">Dashboard</a>
    <a href="owners.html">Owners</a>
    <a href="orphans.html">Orphans (0)</a>
